# Copy to .env and fill in. Never commit .env.

# PalletTrade MCP (required) — token looks like pt_mcp_...
PALLET_TRADE_TOKEN=

# Anthropic API key (required for analysis)
ANTHROPIC_API_KEY=

# eBay Browse API app credentials (optional but recommended — tier-1 image source).
# Register a free dev account at developer.ebay.com, create a production keyset.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Discord webhook URL (optional — notifications are skipped if unset)
DISCORD_WEBHOOK_URL=

# Server port (default 8787)
PORT=8787
